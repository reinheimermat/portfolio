---
interface Props {
    name: string;
    role: string;
    description: string;
    src: string;
    alt: string;
    relation: string;
}

const { name, role, description, src, alt, relation } = Astro.props;
---

<div class="flex gap-2">
    <img src={src} alt={alt} class="rounded-full size-12" />

    <div class="space-y-3">
        <div>
            <h2 class="font-bold">{name}</h2>
            <p class="text-sm text-zinc-700 dark:text-zinc-300">{role}</p>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">{relation}</p>
        </div>
        <p class="text-sm w-2/3">{description}</p>
    </div>
</div>
